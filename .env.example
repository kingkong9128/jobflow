# Database - SQLite (file path)
DATABASE_URL="file:./jobflow.db"

# Server
PORT=4000
FRONTEND_URL=http://localhost:4001

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Providers (at least one required)
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# MiniMax
MINIMAX_API_KEY=...
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# Default AI provider (optional, defaults to 'anthropic')
AI_PROVIDER=minimax

# Job APIs
JOOBLE_API_KEY=
INDEED_API_KEY=
ADZUNA_API_KEY=
ADZUNA_APP_ID=

# File Storage (optional - defaults to local './uploads')
UPLOAD_DIR=./uploads
STORAGE_TYPE=local

# Email (for job alerts - optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com