// This is your Prisma schema file for SQLite (OpenSource)
// For hosted version with PostgreSQL, use schema.postgres.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  baseCvs       BaseCv[]
  savedJobs     SavedJob[]
  jobAlerts     JobAlert[]
  applications  Application[]
  applySettings ApplySettings?
  cvCustomizations CvCustomization[]
}

model BaseCv {
  id               String   @id @default(uuid())
  userId           String
  filePath         String?
  fileName         String?
  parsedData       String   // JSON stored as text in SQLite
  originalFileName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications   Application[]
  customizations CvCustomization[]

  @@index([userId])
}

model SavedJob {
  id          String    @id @default(uuid())
  userId      String
  source      String    // 'jooble', 'indeed', 'adzuna', 'manual'
  sourceId    String?
  title       String
  company     String?
  location    String?
  remote      Boolean   @default(false)
  salaryMin   Int?
  salaryMax   Int?
  description String?
  url         String?
  postedAt    DateTime?
  savedAt     DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  customizations CvCustomization[]

  @@unique([userId, source, sourceId])
  @@index([userId])
}

model JobAlert {
  id         String   @id @default(uuid())
  userId     String
  name       String?
  criteria   String   // JSON stored as text
  frequency  String   @default("daily") // 'daily', 'weekly'
  active     Boolean  @default(true)
  lastSentAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Application {
  id                String    @id @default(uuid())
  userId            String
  jobId             String?
  baseCvId          String?
  customizedCvPath  String?
  coverLetterPath   String?
  status            String    @default("applied") // applied, in_review, interview, offer, rejected, accepted
  appliedAt         DateTime?
  appliedVia        String    @default("manual") // manual, auto_fill, auto_submit
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    SavedJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  baseCv BaseCv?   @relation(fields: [baseCvId], references: [id])

  @@index([userId])
  @@index([jobId])
}

model ApplySettings {
  userId               String  @id
  autoSubmitEnabled    Boolean @default(false)
  autoSubmitCompanies  Boolean @default(true)
  reviewWindowSeconds  Int     @default(5)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CvCustomization {
  id               String   @id @default(uuid())
  userId           String
  baseCvId         String
  jobId            String?
  customizedData   String   // JSON stored as text
  matchScore       Int?
  createdAt        DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseCv   BaseCv   @relation(fields: [baseCvId], references: [id], onDelete: Cascade)
  job      SavedJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
}